# 環境変数の例 - frontend
# このファイルを .env にコピーして実際の値を設定してください

# Azure Entra ID設定
VITE_AZURE_CLIENT_ID=your-azure-client-id-here
VITE_AZURE_TENANT_ID=your-azure-tenant-id-here
VITE_REDIRECT_URI=https://your-static-web-app.azurestaticapps.net

# Azure Functions
VITE_FUNCTIONS_BASE_URL=https://your-function-app.azurewebsites.net

# Cosmos DB (for client-side read operations if needed)
VITE_COSMOS_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/

# Environment
VITE_ENV=production
